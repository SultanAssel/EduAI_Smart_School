# EduAI — шаблон переменных окружения
# Скопируйте: cp .env.example .env

# Django
# Сгенерировать ключ можно так:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-django-key-here
DEBUG=True

# Для локальной разработки допустимо оставить *.
# Для production укажите домены через запятую без пробелов.
ALLOWED_HOSTS=*

# Для reverse proxy / HTTPS доменов.
# Пример: https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=

# Язык интерфейса по умолчанию: ru, en или kk
DEFAULT_LANGUAGE=ru

# Database
# SQLite по умолчанию:
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL пример:
# DATABASE_URL=postgresql://user:password@localhost:5432/eduai

# AI / LLM
# OpenAI-compatible endpoint: Gemini, OpenAI, Ollama, LM Studio, vLLM
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_MODEL=gemini-2.5-flash
AI_TIMEOUT=25

# OpenAI пример:
# AI_API_KEY=sk-your-openai-key
# AI_BASE_URL=https://api.openai.com/v1/
# AI_MODEL=gpt-4o-mini

# Ollama пример:
# AI_API_KEY=ollama
# AI_BASE_URL=http://localhost:11434/v1/
# AI_MODEL=llama3.2

# Email
# Для локальной разработки можно оставить console backend.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=EduAI <noreply@example.com>

# Media
MEDIA_URL=/media/
MEDIA_ROOT=media

# Security
# Для production обычно нужно включить, если трафик идет через HTTPS.
# SECURE_SSL_REDIRECT=True

# Port for gunicorn / PaaS environments
# PORT=8000
